#!/usr/bin/env bun

const USAGE = `greview - PR code review in worktrees with Claude

Usage:
  greview [github-url|graphite-url|pr-number|branch-name]

  Without args, lists PRs requesting your review (last 2 weeks) via fzf.

Examples:
  greview
  greview https://github.com/gamma-app/gamma/pull/4521
  greview https://app.graphite.com/github/pr/gamma-app/gamma/4521
  greview 4521
  greview jordan/my-feature

Note: run from the target repo directory. Worktree is cleaned up on exit.`;

function parsePR(input: string): number | null {
  if (/^\d+$/.test(input)) return parseInt(input);

  // github.com/owner/repo/pull/123
  const gh = input.match(/github\.com\/[^/]+\/[^/]+\/pull\/(\d+)/);
  if (gh) return parseInt(gh[1]);

  // app.graphite.com/github/pr/owner/repo/123
  const gr = input.match(/graphite\.(?:com|dev)\/github\/pr\/[^/]+\/[^/]+\/(\d+)/);
  if (gr) return parseInt(gr[1]);

  return null;
}

async function prBranch(pr: number): Promise<string> {
  const proc = Bun.spawn(
    ["gh", "pr", "view", String(pr), "--json", "headRefName", "-q", ".headRefName"],
    { stdout: "pipe", stderr: "pipe" }
  );
  const out = await new Response(proc.stdout).text();
  const code = await proc.exited;
  if (code !== 0) {
    console.error(`failed to resolve branch for PR #${pr}`);
    process.exit(1);
  }
  return out.trim();
}

async function pickPR(): Promise<number> {
  const twoWeeksAgo = new Date(Date.now() - 14 * 86400000).toISOString().slice(0, 10);
  const fields = "number,title,author,additions,deletions,reviewDecision,createdAt";
  const proc = Bun.spawn(
    ["gh", "pr", "list", "--search", `review-requested:@me created:>=${twoWeeksAgo}`, "--json", fields, "--limit", "50"],
    { stdout: "pipe", stderr: "pipe" }
  );
  const out = await new Response(proc.stdout).text();
  if ((await proc.exited) !== 0) {
    console.error("failed to fetch review-requested PRs");
    process.exit(1);
  }
  type PR = { number: number; title: string; author: { login: string }; additions: number; deletions: number; reviewDecision: string; createdAt: string };
  const prs = (JSON.parse(out) as PR[]).filter((p) => p.reviewDecision !== "APPROVED");
  if (!prs.length) {
    console.log("no PRs requesting your review in the last 2 weeks");
    process.exit(0);
  }

  const green = "\x1b[32m";
  const red = "\x1b[31m";
  const gray = "\x1b[90m";
  const reset = "\x1b[0m";
  const dim = "\x1b[2m";
  const pad = (s: string, n: number) => s.length > n ? s.slice(0, n) : s.padEnd(n);
  const relTime = (iso: string) => {
    const ms = Date.now() - new Date(iso).getTime();
    const m = Math.floor(ms / 60000);
    if (m < 60) return `${m}m`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h`;
    return `${Math.floor(h / 24)}d`;
  };
  const sp = "   ";
  const header = `${"PR#".padEnd(7)}${sp}${pad("Author", 12)}${sp}${"Title".padEnd(60)}${sp}${"Age".padEnd(5)}${sp}+/-`;
  const lines = prs.map((p) => {
    const num = String(p.number).padEnd(7);
    const author = pad(p.author.login, 12);
    const title = pad(p.title, 60);
    const age = `${gray}${pad(relTime(p.createdAt), 5)}${reset}`;
    const adds = `${green}+${p.additions}${reset}`;
    const dels = `${red}-${p.deletions}${reset}`;
    return `${p.number}\t${dim}${num}${reset}${sp}${author}${sp}${title}${sp}${age}${sp}${adds}${dim}/${reset}${dels}`;
  }).join("\n");
  const fzf = Bun.spawn(
    ["fzf", "--header", header, "--with-nth", "2..", "--delimiter", "\t", "--ansi", "--reverse"],
    { stdin: "pipe", stdout: "pipe", stderr: "inherit" }
  );
  fzf.stdin.write(lines);
  fzf.stdin.end();
  const selected = (await new Response(fzf.stdout).text()).trim();
  if ((await fzf.exited) !== 0 || !selected) {
    process.exit(1);
  }
  return parseInt(selected.split("\t")[0]);
}

const input = process.argv[2];
if (input === "--help" || input === "-h") {
  console.log(USAGE);
  process.exit(0);
}

if (!process.cwd().startsWith("/Users/jordan/code/gamma")) {
  process.chdir("/Users/jordan/code/gamma");
}

let pr: number;
if (!input) {
  pr = await pickPR();
} else {
  const parsed = parsePR(input);
  if (parsed) {
    pr = parsed;
  } else {
    const lookup = Bun.spawn(
      ["gh", "pr", "list", "--head", input, "--json", "number", "-q", ".[0].number"],
      { stdout: "pipe", stderr: "pipe" }
    );
    const out = await new Response(lookup.stdout).text();
    const code = await lookup.exited;
    const num = parseInt(out.trim());
    if (code !== 0 || isNaN(num)) {
      console.error(`no PR found for branch: ${input}`);
      process.exit(1);
    }
    pr = num;
  }
}

const prompt = [
  `Load context for PR #${pr}:`,
  `1. \`gh pr view ${pr} --json title,body,url\` to get PR info`,
  `2. \`gh pr diff ${pr}\` to see the diff`,
  `3. \`gh api repos/{owner}/{repo}/pulls/${pr}/comments\` and \`gh api repos/{owner}/{repo}/pulls/${pr}/reviews\` to load review comments`,
  `4. Read the changed files for full context`,
  ``,
  `You are in a worktree checked out to the PR's branch, so you can read any file directly.`,
  `Do NOT edit or commit any code. This is a read-only review. When you have feedback, leave comments on the PR using \`gh\`.`,
  `Do NOT review or give feedback unless asked. Give a concise 5 bullet summary of what changed in this PR. Stay high-level — describe what the PR does and the general approach, not specific class/method/variable names or implementation details.`,
].join("\n");

// resolve branch before launching so we can clean up after
const branch = await prBranch(pr);

const proc = Bun.spawn(
  ["wt", "switch", `pr:${pr}`, "-x", "claude", "--", "--dangerously-skip-permissions", prompt],
  { stdio: ["inherit", "inherit", "inherit"] }
);
await proc.exited;

// cleanup worktree after claude exits
const rm = Bun.spawn(["wt", "remove", "-D", branch], {
  stdio: ["inherit", "inherit", "inherit"],
});
await rm.exited;
